{
  "name": "ai-tech-job-matcher",
  "version": "1.2.0",
  "private": true,
  "description": "A TypeScript project that uses Playwright, AI and Excel reports to match tech resumes with public job opportunities.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "postbuild": "node scripts/copy-web-assets.mjs",
    "start": "node dist/index.js",
    "start:web": "node dist/web/server.js",
    "test": "playwright test",
    "test:unit": "playwright test tests/unit",
    "test:e2e": "playwright test tests/e2e",
    "test:dist": "node scripts/smoke-dist.mjs",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:screenshot": "npm run build && node scripts/capture-readme-screenshot.mjs",
    "demo:qa": "tsx src/index.ts --resume ./samples/sample-resume.txt --role qa --source gupy --work-mode remote --limit 10 --fallback",
    "demo:all": "tsx src/index.ts --resume ./samples/sample-resume.txt --role all --source all --limit 16 --fallback",
    "sources:check": "tsx src/tools/checkSources.ts",
    "web": "tsx src/web/server.ts"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa-automation",
    "web-scraping",
    "ai",
    "resume-analysis",
    "excel-report",
    "job-matching"
  ],
  "author": "João Vitor da Silva",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JoaovSilva2005/ai-tech-job-matcher.git"
  },
  "bugs": {
    "url": "https://github.com/JoaovSilva2005/ai-tech-job-matcher/issues"
  },
  "homepage": "https://github.com/JoaovSilva2005/ai-tech-job-matcher#readme",
  "engines": {
    "node": ">=22.3.0"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "mammoth": "^1.8.0",
    "multer": "^2.2.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.49.0",
    "robots-parser": "^3.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.6",
    "eslint": "^9.17.0",
    "jszip": "^3.10.1",
    "pdfkit": "^0.19.1",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
