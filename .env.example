# AI provider: "fallback" (default, no API key needed), "openai", "anthropic" or "gemini".
# If the selected provider has no API key, the app automatically falls back
# to the local keyword-based analyzer.
AI_PROVIDER=fallback
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash-lite

# Reliability controls for remote AI calls
AI_REQUEST_TIMEOUT_MS=20000
AI_MAX_RETRIES=1
AI_RETRY_DELAY_MS=250
AI_JOB_CONCURRENCY=2

# Optional: public ATS source configuration.
# Greenhouse uses up to five public board tokens. Defaults to "stripe" when empty.
GREENHOUSE_BOARD_TOKENS=

# Gupy uses public Brazilian career pages. Defaults to Topaz Brasil, Quality Digital and SiDi.
# Example: https://topazbrasil.gupy.io/,https://sidi.gupy.io/
GUPY_CAREER_URLS=

# Lever accepts up to five known public company slugs; comma-separate more than one.
# Example: jobgether
LEVER_COMPANY_SLUGS=

# Ashby accepts up to five public board names. The final segment in
# https://jobs.ashbyhq.com/Ashby is the board name. Defaults to "Ashby".
ASHBY_BOARD_NAMES=Ashby

# Recruitee accepts up to five public careers-site subdomains.
# Example: acme for https://acme.recruitee.com
RECRUITEE_COMPANY_SUBDOMAINS=

# Jooble requires a key requested at https://br.jooble.org/api/about.
# Candidate location overrides JOOBLE_LOCATION when provided in the app.
JOOBLE_API_KEY=
JOOBLE_LOCATION=Brasil

# SmartRecruiters public Posting API uses company identifiers. The key is optional
# for public postings and is sent as X-SmartToken when configured.
SMARTRECRUITERS_COMPANY_IDS=smartrecruiters
SMARTRECRUITERS_API_KEY=

# Optional documented Jobicy region slug, for example brazil or latam.
JOBICY_GEO=

# Up to five explicitly authorized job-detail pages containing JSON-LD JobPosting.
# The collector checks robots.txt and rejects local/private URLs.
JSONLD_JOB_URLS=

# RemoteOK, Remotive, The Muse, Greenhouse, Gupy, Ashby, SmartRecruiters,
# Jobicy and Arbeitnow can run without API keys.
