# AI provider: "fallback" (default, no API key needed), "openai", "anthropic" or "gemini".
# If the selected provider has no API key, the app automatically falls back
# to the local keyword-based analyzer.
AI_PROVIDER=fallback
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Optional model overrides
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-sonnet-5
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: URL used by the "generic" best-effort scraper source.
# Must be a public job board that does not require login or captcha.
GENERIC_JOBS_URL=

# Optional: public ATS source configuration.
# Greenhouse uses public board tokens. Defaults to "stripe" when empty.
GREENHOUSE_BOARD_TOKENS=

# Lever requires known public company slugs; comma-separate more than one.
# Example: jobgether
LEVER_COMPANY_SLUGS=

# Note: "remotive", "remoteok", "themuse" and "greenhouse" can run with no API keys.
